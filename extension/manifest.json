{
  "manifest_version": 3,
  "name": "SocyBase Browser Operator",
  "version": "1.0.0",
  "description": "Lend a tab to SocyBase for AI-Scraping tasks on restricted Facebook pages",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://mbasic.facebook.com/*",
    "https://*.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.socybase.com/*", "https://*.up.railway.app/*", "http://localhost:3000/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
